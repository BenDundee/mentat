# Required: OpenRouter API key for LLM access
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Optional: deployment environment (development | production)
ENVIRONMENT=development

# Optional: directory for persisted data (sessions, uploads)
# Override to /app/data when running in Docker
DATA_DIR=data

# Optional: server host and port
HOST=0.0.0.0
PORT=8000

# Neo4j AuraDB connection (required for Phase 9+)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Embeddings use OPENROUTER_API_KEY (no separate key needed)
# Change the model in configs/embedding.yml
